<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.comicverse.controller.LoginController"
      prefWidth="350" prefHeight="400"
      style="-fx-background-color: #1a1a2e;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- Título -->
    <Label text="ComicVerse"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label text="Inicia sesión en tu cuenta"
           style="-fx-font-size: 14px; -fx-text-fill: #aaaaaa;"/>

    <!-- Campo email -->
    <TextField fx:id="txtEmail"
               promptText="Correo electrónico"
               style="-fx-background-color: #2a2a4a; -fx-text-fill: white; -fx-prompt-text-fill: #aaaaaa; -fx-background-radius: 8; -fx-padding: 10;"/>

    <!-- Campo contraseña -->
    <PasswordField fx:id="txtContrasena"
                   promptText="Contraseña"
                   style="-fx-background-color: #2a2a4a; -fx-text-fill: white; -fx-prompt-text-fill: #aaaaaa; -fx-background-radius: 8; -fx-padding: 10;"/>

    <!-- Mensaje de error -->
    <Label fx:id="lblError"
           text=""
           style="-fx-text-fill: #ff4444; -fx-font-size: 12px;"/>

    <!-- Botón entrar -->
    <Button fx:id="btnEntrar"
            text="Entrar"
            onAction="#handleLogin"
            maxWidth="Infinity"
            style="-fx-background-color: #e63946; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10;"/>

    <!-- Link registro -->
    <Label text="¿No tienes cuenta? Regístrate"
           style="-fx-text-fill: #4dabf7; -fx-cursor: hand;"
           onMouseClicked="#handleRegistro"/>

</VBox>
